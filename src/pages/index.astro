---
import { Image } from "astro:assets";
import { FolderGit2, Link, Mail } from "@lucide/astro";
import ArchiveItem from "../components/ArchiveItem.astro";
import ModuleCard from "../components/ModuleCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SiteFooter from "../components/SiteFooter.astro";
import TopNavigation from "../components/TopNavigation.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import heroImage from "../assets/aa_web.webp";

const moduleCards = [
  {
    code: "MOD_01",
    title: "INTERFACE_DEV",
    description:
      "React, TypeScript, Next.js, Remix, responsive UI engineering, performance optimization, and frontend testing.",
    icon: "architecture",
    accent: "secondary" as const,
  },
  {
    code: "MOD_02",
    title: "BACKEND_RUNTIME",
    description:
      "Node.js, API development, server-side architecture, integrations, and application logic for production systems.",
    icon: "developer_board",
    accent: "primary" as const,
  },
  {
    code: "MOD_03",
    title: "DATA_LAYER",
    description:
      "PostgreSQL, relational schema design, querying, performance-aware data access, and reliable persistence workflows.",
    icon: "database",
    accent: "secondary" as const,
  },
  {
    code: "MOD_04",
    title: "CLOUD_DEVOPS",
    description:
      "AWS, Docker, deployment workflows, environment management, and scalable delivery pipelines.",
    icon: "cloud_upload",
    accent: "primary" as const,
  },
];

const archiveItems = [
  {
    period: "MAY 2025 - PRESENT",
    company: "THRILLOPHILIA",
    location: "JAIPUR",
    title: "SENIOR SOFTWARE ENGINEER",
    bullets: [
      "Decoupled the React app from the Ruby on Rails framework and migrated the bundler to Vite, reducing frontend and backend build time by over 95%.",
      "Implemented multi-payment support on the checkout page to improve the experience of thousands of monthly users.",
      "Led the frontend of the AI-based itinerary builder, improving the time to share an itinerary with end users by over 60%.",
      "Integrated ESLint and Prettier GitHub Action to improve and maintain code quality.",
      "Integrated Playwright for E2E testing to improve product reliability, including coverage for the login flow under E2E tests.",
    ],
    highlighted: true,
  },
  {
    period: "OCT 2024 - APRIL 2025",
    company: "POSTMAN",
    location: "BENGALURU",
    title: "SOFTWARE ENGINEER II",
    bullets: [
      "Implemented UI/UX improvements to mock servers at Postman, reducing the number of steps needed to create a mock server for nearly 56 million paid users.",
      "Added support for loading collection diff asynchronously, improving efficiency for large orgs that rely on these large diffs.",
      "Improved the UI of the collection sidebar context menu, enhancing usability, responsiveness, and logical grouping of menu actions.",
    ],
  },
  {
    period: "APRIL 2024 - OCT 2024",
    company: "JIO HAPTIK, RELIANCE JIO PLATFORM",
    location: "Mumbai",
    title: "SOFTWARE ENGINEER III, FRONTEND",
    hideDivider: true,
    bullets: [
      "Led the migration to Vite bundler and React 18, resulting in a 40% improvement in re-rendering performance and a 70% reduction in build time, with better hot reload performance and roughly 20% higher developer productivity.",
      "Held weekly review meetings with the team for technical discussion, feedback, and engineering growth.",
    ],
  },
  {
    period: "MAY 2021 - MARCH 2024",
    company: "",
    location: "",
    title: "SOFTWARE ENGINEER II, FRONTEND",
    bullets: [
      "Worked on features including WhatsApp carousel card templates, Instagram, Announcement Hub, and Ad Performance, ensuring strong UX across desktop and mobile web platforms.",
      "Enhanced Inbox performance by over 30%, improving user engagement.",
      "Worked on Storybook and design system integration, improving design consistency across the project and increasing developer productivity.",
      "Identified and improved the UX of Instagram's embedded signup flow, increasing signup success rate from 14% to 71%.",
    ],
  },
  {
    period: "OCT 2019 - MARCH 2021",
    company: "APPLAUNCH",
    location: "BENGALURU",
    title: "REACT JS TEAM LEAD AND REACT NATIVE DEVELOPER",
    bullets: [
      "Led and mentored the React JS team, establishing coding standards and best practices.",
      "Worked on two React Native projects, including an audio live-streaming platform.",
    ],
  },
  {
    period: "JAN 2018 - OCT 2019",
    company: "CBETTER",
    location: "JAIPUR",
    title: "WEB DEVELOPER",
    bullets: [
      "Worked on various frontend and CMS projects, including a website for AUBank Foundation and an interactive schedule portal for the Nasscom Product Conclave.",
    ],
  },
];
---

<BaseLayout
  title="Ankitesh Arora | Senior Software Engineer"
  description="Portfolio of Ankitesh Arora featuring frontend engineering experience, selected work history, technical strengths, and contact links."
  canonicalPath="/"
>
  <div id="top">
    <TopNavigation />
    <main class="mx-auto max-w-7xl space-y-16 px-6 pb-32 pt-24">
      <section
        id="system"
        class="grid grid-cols-1 gap-0 border-4 border-ink bg-panel lg:grid-cols-12"
      >
        <div
          class="flex flex-col justify-between border-b-4 border-ink p-8 lg:col-span-8 lg:border-r-4 lg:border-b-0"
        >
          <div class="space-y-4">
            <div
              class="flex items-center gap-2 font-label text-xs uppercase tracking-widest text-ink-muted"
            >
              <span class="h-2 w-2 animate-pulse bg-accent"></span>
              SYSTEM_STATUS: OPERATIONAL
            </div>
            <h1
              class="font-headline text-5xl leading-[0.85] font-bold uppercase tracking-tighter md:text-6xl lg:text-7xl"
            >
              SENIOR<br />SOFTWARE ENGINEER<br /><span class="text-ink-muted">
                _FRONTEND
              </span>
            </h1>
          </div>

          <div class="mt-12 flex flex-wrap gap-4 font-label text-sm">
            <a
              class="border border-ink bg-ink px-4 py-2 text-canvas"
              href="https://calendly.com/ankitesh4/30min"
              target="_blank"
              rel="noreferrer"
            >
              INITIATE_PROTOCOL
            </a>
            <a
              class="cursor-pointer border-2 border-ink px-4 py-2 transition-colors hover:bg-accent hover:text-accent-foreground"
              href="#archive"
            >
              VIEW_ARCHIVE.SH
            </a>
          </div>
        </div>

        <div class="relative min-h-[400px] overflow-hidden lg:col-span-4">
          <Image
            class="absolute inset-0 h-full w-full object-cover grayscale contrast-125 brightness-110"
            src={heroImage}
            alt="Close-up portrait of a professional engineer in a high-contrast black and white aesthetic with dramatic technical lighting"
            sizes="(min-width: 1024px) 33vw, 100vw"
            loading="eager"
            format="webp"
          />
          <div class="absolute inset-0 bg-accent/10 mix-blend-multiply"></div>
          <div
            class="absolute bottom-4 left-4 bg-ink px-2 py-1 font-label text-[10px] text-canvas"
          >
            UID: 0b101010_AA
          </div>
        </div>
      </section>

      <section id="stack" class="space-y-6">
        <SectionHeading title="01_CORE_MODULES" meta="[LOAD_SEQUENCE: 100%]" />
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
          {moduleCards.map((card) => <ModuleCard {...card} />)}
        </div>
      </section>

      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12">
        <section id="archive" class="space-y-6 lg:col-span-8">
          <SectionHeading title="02_WORK_ARCHIVE" meta="[CAREER_TIMELINE]" />
          <div class="border-2 border-ink bg-panel">
            {archiveItems.map((item) => <ArchiveItem {...item} />)}
          </div>
        </section>

        <section class="space-y-6 lg:col-span-4">
          <SectionHeading title="03_CREDENTIALS" />

          <article
            class="relative overflow-hidden border-2 border-secondary bg-secondary-panel text-secondary-panel-foreground"
          >
            <div
              class="absolute left-0 top-0 h-16 w-16 border-r border-b border-secondary/30"
            >
            </div>
            <div
              class="absolute bottom-0 right-0 h-20 w-20 border-l border-t border-secondary/25"
            >
            </div>

            <div
              class="relative border-[3px] border-secondary/35 m-2 p-6 md:p-7"
            >
              <div class="flex items-start justify-between gap-6">
                <div>
                  <div
                    class="font-label text-[10px] uppercase tracking-[0.28em] text-secondary/80"
                  >
                    Education
                  </div>
                  <h3 class="mt-4 text-2xl font-bold leading-none">
                    JECRC, Jaipur
                  </h3>
                </div>

                <div
                  class="shrink-0 border border-secondary/40 bg-secondary-panel-foreground/5 px-3 py-2 text-right font-label text-[11px] leading-tight tracking-[0.24em] text-secondary/80 flex"
                >
                  <div>2014</div>
                  <div>-</div>
                  <div>2018</div>
                </div>
              </div>

              <div class="mt-8 border-t border-secondary/30 pt-6">
                <div
                  class="font-label text-[10px] uppercase tracking-[0.24em] text-secondary/70"
                >
                  Degree Program
                </div>
                <p
                  class="mt-3 max-w-xs text-2xl leading-snug italic md:text-[2rem]"
                >
                  Btech, Information Technology
                </p>
              </div>

              <div
                class="mt-8 flex items-center justify-between border-t border-secondary/20 pt-4 font-label text-[10px] uppercase tracking-[0.24em] text-secondary/65"
              >
                <span>Academic Record</span>
                <span>Credential Verified</span>
              </div>
            </div>
          </article>
        </section>
      </div>

      <section
        id="contact"
        class="flex flex-col items-center space-y-8 border-t-4 border-ink pt-12 text-center sm:pt-16"
      >
        <div class="max-w-2xl px-4 sm:px-0">
          <h2
            class="font-headline text-[clamp(2.5rem,10vw,4rem)] leading-[0.9] font-bold uppercase tracking-[-0.06em] sm:tracking-tighter"
          >
            OPEN_CHANNEL
          </h2>
          <p
            class="mt-4 text-pretty font-body text-lg leading-relaxed text-ink-muted sm:text-xl"
          >
            Have an exicting project you need help with? Drop a email!
          </p>
        </div>

        <div
          class="flex w-full max-w-4xl flex-col border-2 border-ink sm:flex-row"
        >
          <a
            class="flex min-h-20 w-full items-center justify-center gap-3 border-b-2 border-ink bg-secondary px-6 py-5 text-center font-bold text-secondary-foreground transition-colors hover:bg-ink hover:text-accent sm:min-h-0 sm:flex-1 sm:border-r-2 sm:border-b-0 sm:px-8 sm:py-4"
            href="mailto:ankitesh4@gmail.com"
          >
            <Mail class="h-5 w-5" aria-hidden="true" />
            SEND_MAIL
          </a>
          <a
            class="flex min-h-20 w-full items-center justify-center gap-3 border-b-2 border-ink bg-canvas px-6 py-5 text-center font-bold text-ink transition-colors hover:bg-accent dark:hover:bg-accent-foreground sm:min-h-0 sm:flex-1 sm:border-r-2 sm:border-b-0 sm:px-8 sm:py-4"
            href="https://github.com/ankitesh10"
            target="_blank"
          >
            <FolderGit2 class="h-5 w-5" aria-hidden="true" />
            GITHUB.LOG
          </a>
          <a
            class="flex min-h-20 w-full items-center justify-center gap-3 bg-canvas px-6 py-5 text-center font-bold text-ink transition-colors hover:bg-secondary sm:min-h-0 sm:flex-1 sm:px-8 sm:py-4"
            href="https://www.linkedin.com/in/ankitesharora/"
            target="_blank"
          >
            <Link class="h-5 w-5" aria-hidden="true" />
            LINKEDIN_PROF
          </a>
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
</BaseLayout>
