---
import BaseLayout from "../layouts/BaseLayout.astro";
import TopNavigation from "../components/TopNavigation.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { SITE_URL, pageMetadata } from "../data/pageMetadata";

const resumeUrl = "resume_frontend_engineer_ankitesh.pdf";
const resumePreviewUrl =
  "resume_frontend_engineer_ankitesh.pdf#toolbar=0&navpanes=0&scrollbar=0&view=FitH";
const resumePage = pageMetadata.resume;
const resumeStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: resumePage.title,
    url: `${SITE_URL}${resumePage.path}`,
    description: resumePage.description,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: `${SITE_URL}${pageMetadata.home.path}`,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Resume",
        item: `${SITE_URL}${resumePage.path}`,
      },
    ],
  },
];
---

<BaseLayout
  title={resumePage.title}
  description={resumePage.description}
  canonicalPath={resumePage.path}
  structuredData={resumeStructuredData}
>
  <TopNavigation />

  <main
    id="main-content"
    class="mx-auto px-6 pb-10 pt-10 my-auto max-w-5xl 2xl:max-w-6xl h-dvh flex items-center justify-center"
  >
    <section
      class="overflow-hidden border-4 border-ink bg-panel shadow-[12px_12px_0_0_var(--color-ink)] dark:shadow-[12px_12px_0_0_var(--color-secondary-panel)]"
    >
      <header
        class="flex flex-col gap-6 border-b-4 border-ink bg-panel-soft px-6 py-4 text-ink md:flex-row md:items-center md:justify-between"
      >
        <div class="space-y-2">
          <p
            class="font-label text-[11px] tracking-[0.3em] break-all text-ink-muted uppercase"
          >
            Preview source:
            <span class="text-accent-strong-foreground dark:text-accent-strong"
              >{resumeUrl}</span
            >
          </p>
        </div>

        <div class="flex flex-wrap gap-3 font-label text-xs tracking-[0.2em]">
          <a
            href={resumeUrl}
            target="_blank"
            rel="noreferrer"
            class="border-2 border-chrome-border bg-chrome px-4 py-3 text-chrome-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
          >
            open_pdf
          </a>
          <a
            href={resumeUrl}
            download
            class="border-2 border-accent bg-panel px-4 py-3 text-accent-strong-foreground transition-colors hover:bg-accent hover:text-accent-foreground dark:text-accent"
          >
            download
          </a>
        </div>
      </header>

      <div class="bg-panel-muted p-2">
        <div
          class="overflow-hidden border-2 border-ink bg-white shadow-[0_0_0_1px_var(--color-panel-strong)]"
        >
          <iframe
            src={resumePreviewUrl}
            title="Resume PDF Preview"
            class="h-[60dvh] w-full lg:h-[67dvh]"></iframe>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
