---
import BaseLayout from "../layouts/BaseLayout.astro";
import TopNavigation from "../components/TopNavigation.astro";
import SiteFooter from "../components/SiteFooter.astro";

const resumeUrl = "resume_frontend_engineer_ankitesh.pdf";
const resumePreviewUrl =
  "resume_frontend_engineer_ankitesh.pdf#toolbar=0&navpanes=0&scrollbar=0&view=FitH";
---

<BaseLayout title="RESUME // ANKITESH_ARORA">
  <TopNavigation />

  <main
    class="mx-auto px-6 pb-10 pt-10 my-auto max-w-5xl 2xl:max-w-6xl h-dvh flex items-center justify-center"
  >
    <section
      class="overflow-hidden border-4 border-ink bg-panel shadow-[12px_12px_0_0_var(--color-ink)]"
    >
      <header
        class="flex flex-col gap-6 border-b-4 border-ink bg-accent px-6 py-3 text-accent-foreground md:flex-row md:items-center md:justify-between"
      >
        <div class="space-y-2">
          <p class="font-label text-xs tracking-[0.3em] break-all">
            Preview source: <span class="text-ink">{resumeUrl}</span>
          </p>
        </div>

        <div class="flex flex-wrap gap-3 font-label text-xs tracking-[0.2em]">
          <a
            href={resumeUrl}
            target="_blank"
            rel="noreferrer"
            class="border-2 border-accent-foreground bg-ink px-4 py-3 text-canvas transition-colors hover:bg-canvas hover:text-ink"
          >
            open_pdf
          </a>
          <a
            href={resumeUrl}
            download
            class="border-2 border-accent-foreground px-4 py-3 transition-colors hover:bg-accent-foreground hover:text-ink"
          >
            download
          </a>
        </div>
      </header>

      <div class="bg-canvas">
        <div class="overflow-hidden border-2 border-ink bg-white">
          <iframe
            src={resumePreviewUrl}
            title="Resume PDF Preview"
            class="h-[60dvh] w-full lg:h-[70dvh]"></iframe>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
