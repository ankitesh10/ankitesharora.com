---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import TopNavigation from "../components/TopNavigation.astro";
import "@xterm/xterm/css/xterm.css";
---

<BaseLayout title="ANKITESH_ARORA_V1.0 // LIGHT_ARCHIVE">
  <main
    class="mx-auto flex min-h-[calc(100dvh-3rem)] max-w-7xl items-center px-6 pt-12 pb-16 md:pt-16"
  >
    <section
      class="w-full overflow-hidden border-4 border-ink bg-panel shadow-[12px_12px_0_0_var(--color-ink)]"
    >
      <TopNavigation />

      <header
        class="flex items-center justify-between gap-4 border-b-4 border-ink bg-accent px-5 py-4 text-accent-foreground"
      >
        <div>
          <p class="font-label text-xs uppercase tracking-[0.3em]">
            TERMINAL_NODE;
          </p>
          <h1 class="font-headline text-xl font-bold uppercase tracking-tight">
            AA_BOT_INTERFACE;
          </h1>
        </div>
        <div class="font-label text-xs tracking-[0.25em]">
          STATUS: UNDER_DEVELOPMENT;
        </div>
      </header>

      <div
        class="border-b-4 border-ink bg-panel-muted px-5 py-3 font-label text-xs uppercase tracking-[0.2em] text-ink-muted flex justify-between"
      >
        <span>BOOT_SEQUENCE: OK;</span>
        <span>SESSION: LOCALHOST / PROTOCOL: XTERM;</span>
      </div>

      <div class="terminal-shell overflow-hidden px-5 h-[calc(100dvh-17rem)]">
        <div id="terminal" class="h-full w-full"></div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .terminal-shell {
    background: var(--color-chrome);
  }

  #terminal {
    overflow: hidden;
    background: var(--color-chrome);
  }

  #terminal :global(.xterm) {
    height: 100%;
    background: var(--color-chrome);
  }

  #terminal :global(.xterm-screen),
  #terminal :global(.xterm-viewport) {
    height: 100% !important;
    background: var(--color-chrome);
  }

  #terminal :global(.xterm-viewport) {
    overflow-y: auto;
  }
</style>

<script>
  import { Terminal } from "@xterm/xterm";

  const getTerminalBackground = () =>
    getComputedStyle(document.documentElement)
      .getPropertyValue("--color-chrome")
      .trim() || "hsl(0 0% 5.5%)";

  const getTerminalPalette = () => ({
    background: getTerminalBackground(),
    foreground: "hsl(0 0% 97.6%)",
    cursor: "hsl(115 100% 78.8%)",
    cursorAccent: getTerminalBackground(),
    selectionBackground:
      "color-mix(in srgb, hsl(115 100% 78.8%) 28%, transparent)",
    black: getTerminalBackground(),
    red: "hsl(12 100% 65.9%)",
    green: "hsl(115 100% 78.8%)",
    yellow: "color-mix(in srgb, hsl(115 100% 78.8%) 55%, hsl(0 0% 97.6%))",
    blue: "hsl(186 100% 49.6%)",
    magenta: "color-mix(in srgb, hsl(12 100% 65.9%) 45%, hsl(0 0% 97.6%))",
    cyan: "hsl(186 100% 49.6%)",
    white: "hsl(0 0% 97.6%)",
    brightBlack: "hsl(0 0% 33.3%)",
    brightRed: "color-mix(in srgb, hsl(12 100% 65.9%) 70%, hsl(0 0% 97.6%))",
    brightGreen: "color-mix(in srgb, hsl(115 100% 78.8%) 70%, hsl(0 0% 97.6%))",
    brightYellow:
      "color-mix(in srgb, hsl(115 100% 78.8%) 40%, hsl(0 0% 97.6%))",
    brightBlue: "color-mix(in srgb, hsl(186 100% 49.6%) 70%, hsl(0 0% 97.6%))",
    brightMagenta:
      "color-mix(in srgb, hsl(12 100% 65.9%) 30%, hsl(0 0% 97.6%))",
    brightCyan: "color-mix(in srgb, hsl(186 100% 49.6%) 40%, hsl(0 0% 97.6%))",
    brightWhite: "hsl(0 0% 97.6%)",
  });

  const terminalElement = document.getElementById("terminal");

  if (terminalElement) {
    function convertStringToBlue(text: string) {
      return `\x1B[3;34m${text}\x1B[0m`;
    }

    const term = new Terminal({
      cursorBlink: true,
      convertEol: true,
      fontFamily: '"Space Grotesk", monospace',
      fontSize: 13,
      lineHeight: 1.2,
      theme: getTerminalPalette(),
    });

    const botuser = `${convertStringToBlue("aa_bot@ ankitesharora.com:~$ ")}`;
    const vistor = `${convertStringToBlue("visitor@ ankitesharora.com:~$ ")}`;

    term.open(terminalElement);
    term.write(botuser);
    term.write(`Hello from \x1B[1;3;31maa_bot\x1B[0m. Ask anything about me!`);
    term.writeln("");
    term.write(vistor);

    let input = "";

    term.onData((e) => {
      if (e === "\r") {
        // Enter key
        input = "";
        term.write("\r\n");
        term.write(`${vistor}I am still under development :(`);
        term.writeln("");
        term.write(vistor);
      } else if (e === "\x7f") {
        // Backspace (ASCII DEL)
        // Check if there is text to delete before calling
        if (input.length > 0) {
          input = input.slice(0, -1);
          term.write("\b \b");
        }
      } else {
        input += e;
        term.write(e);
      }
    });

    document.addEventListener("themechange", () => {
      term.options.theme = getTerminalPalette();
      term.refresh(0, term.rows - 1);
    });
  }
</script>
