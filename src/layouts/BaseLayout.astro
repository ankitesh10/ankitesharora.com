---
import "../styles/global.css";
import { DEFAULT_PAGE_DESCRIPTION } from "../data/pageMetadata";

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
}

const {
  title,
  description = DEFAULT_PAGE_DESCRIPTION,
  canonicalPath = Astro.url.pathname,
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://ankitesharora.com");
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const defaultSocialImage = new URL("/favicon.svg", siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Ankitesh Arora" />
    <meta property="og:image" content={defaultSocialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={defaultSocialImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <script is:inline src="/theme-init.js"></script>
    <title>{title}</title>
  </head>

  <body class="app-shell">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class="scanline"></div>
    <slot />
  </body>
</html>
