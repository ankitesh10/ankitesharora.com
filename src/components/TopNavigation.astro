---
import {
  Bot,
  Maximize,
  Menu,
  Minimize,
  Moon,
  Power,
  Sun,
  X,
} from "@lucide/astro";
import ShutdownPopup from "./ShutdownPopup.astro";

const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const currentHash = Astro.url.hash;

const links = [
  { href: "/#system", label: "SYSTEM" },
  { href: "/blog", label: "BLOG" },
  { href: "/resume", label: "RESUME" },
  { href: "/#contact", label: "CONTACT" },
].map((link) => {
  const url = new URL(link.href, Astro.url);
  const linkPath = url.pathname.replace(/\/+$/, "") || "/";
  const isActive = url.hash
    ? currentPath === linkPath &&
      (currentHash ? currentHash === url.hash : url.hash === "#system")
    : currentPath === linkPath;

  return {
    ...link,
    active: isActive,
  };
});

const baseNavLinkClass =
  "px-2 py-1 font-label text-sm uppercase tracking-tighter transition-colors duration-75";
const activeNavLinkClass = "bg-accent text-accent-foreground";
const inactiveNavLinkClass =
  "text-accent hover:bg-secondary/80 hover:text-chrome-foreground";

const icons = [
  {
    label: "Switch to dark mode",
    action: "toggle-theme",
  },
  {
    href: "/bot",
    label: "Open bot page",
    className: "hidden md:inline-block",
  },
];

const iconButtonClass =
  "inline-flex cursor-pointer items-center justify-center rounded-sm p-1 text-accent transition-colors duration-75 hover:bg-accent hover:text-accent-foreground";
const dangerIconButtonClass =
  "inline-flex cursor-pointer items-center justify-center rounded-sm p-1 text-danger transition-colors duration-75 hover:bg-danger hover:text-danger-foreground";
const mobileMenuActionClass =
  "flex min-h-16 w-full flex-col items-center justify-center gap-1 rounded-sm border border-chrome-border px-2 py-2 text-center font-label text-xs uppercase tracking-tighter text-accent transition-colors duration-75 hover:bg-secondary/80 hover:text-chrome-foreground";
---

<nav
  class="fixed top-0 left-0 right-0 z-50 border-b-2 border-chrome-border bg-chrome px-4 text-chrome-foreground shadow-[0_1px_0_0_var(--color-border-muted)] md:px-6"
>
  <div class="flex h-12 items-center justify-between gap-3">
    <a
      href="/"
      class="min-w-0 flex-1 truncate font-headline text-xs font-bold uppercase tracking-[0.2em] text-accent sm:text-sm md:flex-none md:text-base md:tracking-widest"
    >
      ANKITESH_ARORA_V1.0
    </a>

    <div class="hidden gap-4 md:flex">
      {
        links.map(({ href, label, active }) => (
          <a
            href={href}
            data-nav-link
            data-active-class={activeNavLinkClass}
            data-inactive-class={inactiveNavLinkClass}
            class:list={[
              baseNavLinkClass,
              active ? activeNavLinkClass : inactiveNavLinkClass,
            ]}
          >
            {label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-2 text-accent sm:gap-4">
      {
        icons.map((item) => (
          <>
            {item.href ? (
              <div class={item.className}>
                <a
                  href={item.href}
                  aria-label={item.label}
                  title={item.label}
                  class={iconButtonClass}
                >
                  <Bot class="h-5 w-5" aria-hidden="true" />
                </a>
              </div>
            ) : (
              <button
                type="button"
                aria-label={item.label}
                title={item.label}
                data-action={item.action}
                class={iconButtonClass}
              >
                <Sun class="h-5 w-5" data-theme-icon="light" aria-hidden="true" />
                <Moon class="hidden h-5 w-5" data-theme-icon="dark" aria-hidden="true" />
              </button>
            )}
          </>
        ))
      }
      <div class="hidden md:block">
        <button
          type="button"
          aria-label="Enter fullscreen"
          title="Enter fullscreen"
          data-action="toggle-fullscreen"
          class={iconButtonClass}
        >
          <Maximize class="h-5 w-5" data-fullscreen-icon="enter" aria-hidden="true" />
          <Minimize
            class="hidden h-5 w-5"
            data-fullscreen-icon="exit"
            aria-hidden="true"
          />
        </button>
      </div>
      <div class="hidden md:block">
        <button
          type="button"
          aria-label="Power off"
          title="Power off"
          data-action="close-window"
          class={dangerIconButtonClass}
        >
          <Power class="h-5 w-5" aria-hidden="true" />
        </button>
      </div>
      <div class="md:hidden">
        <button
          type="button"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="mobile-navigation-menu"
          data-mobile-menu-button
          class="inline-flex items-center justify-center rounded-sm p-1 text-accent transition-colors duration-75 hover:bg-accent hover:text-accent-foreground"
        >
          <Menu class="h-5 w-5" data-menu-icon="open" aria-hidden="true" />
          <X class="hidden h-5 w-5" data-menu-icon="close" aria-hidden="true" />
        </button>
      </div>

      <ShutdownPopup />
    </div>
  </div>

  <div
    id="mobile-navigation-menu"
    data-mobile-menu
    class="hidden border-t-2 border-chrome-border py-3 md:hidden"
    aria-hidden="true"
  >
    <div class="flex flex-col gap-2">
      {
        links.map(({ href, label, active }) => (
          <a
            href={href}
            data-nav-link
            data-mobile-nav-link
            data-active-class={activeNavLinkClass}
            data-inactive-class={inactiveNavLinkClass}
            class:list={[
              baseNavLinkClass,
              "block w-full",
              active ? activeNavLinkClass : inactiveNavLinkClass,
            ]}
          >
            {label}
          </a>
        ))
      }
    </div>
    <div class="mt-3 border-t-2 border-chrome-border pt-3">
      <div class="grid grid-cols-3 gap-2 rounded-sm p-2">
        <button
          type="button"
          aria-label="Enter fullscreen"
          data-action="toggle-fullscreen"
          class={mobileMenuActionClass}
        >
          <Maximize
            class="h-5 w-5"
            data-fullscreen-icon="enter"
            aria-hidden="true"
          />
          <Minimize
            class="hidden h-5 w-5"
            data-fullscreen-icon="exit"
            aria-hidden="true"
          />
          <span>Fullscreen</span>
        </button>
        <button
          type="button"
          aria-label="Power off"
          data-action="close-window"
          class:list={[
            mobileMenuActionClass,
            "text-danger hover:bg-danger hover:text-danger-foreground",
          ]}
        >
          <Power class="h-5 w-5" aria-hidden="true" />
          <span>Shutdown</span>
        </button>
      </div>
    </div>
  </div>
</nav>

<script>
  const mobileMenuButton = document.querySelector("[data-mobile-menu-button]");
  const mobileMenu = document.querySelector("[data-mobile-menu]");
  const mobileNavLinks = document.querySelectorAll("[data-mobile-nav-link]");
  const themeButton = document.querySelector('[data-action="toggle-theme"]');
  const fullscreenButtons = document.querySelectorAll(
    '[data-action="toggle-fullscreen"]',
  );
  const closeButtons = document.querySelectorAll(
    '[data-action="close-window"]',
  );
  const shutdownOverlay = document.querySelector("[data-shutdown-overlay]");
  const shutdownScreen = document.querySelector("[data-shutdown-screen]");
  const shutdownCancelButton = document.querySelector("[data-shutdown-cancel]");
  const shutdownConfirmButton = document.querySelector(
    "[data-shutdown-confirm]",
  );
  const themeStorageKey = "theme-preference";
  const systemThemeQuery = window.matchMedia("(prefers-color-scheme: dark)");

  function toggleVisibility(element, isVisible, displayClass = "flex") {
    if (!(element instanceof HTMLElement)) {
      return;
    }

    element.classList.toggle("hidden", !isVisible);
    element.classList.toggle(displayClass, isVisible);
    element.setAttribute("aria-hidden", String(!isVisible));
  }

  function toggleMobileMenu(isOpen) {
    toggleVisibility(mobileMenu, isOpen, "block");

    if (!(mobileMenuButton instanceof HTMLButtonElement)) {
      return;
    }

    mobileMenuButton.setAttribute("aria-expanded", String(isOpen));
    const openIcon = mobileMenuButton.querySelector('[data-menu-icon="open"]');
    const closeIcon = mobileMenuButton.querySelector('[data-menu-icon="close"]');

    openIcon?.classList.toggle("hidden", isOpen);
    closeIcon?.classList.toggle("hidden", !isOpen);
  }

  function getPreferredTheme() {
    const storedTheme = localStorage.getItem(themeStorageKey);

    if (storedTheme === "light" || storedTheme === "dark") {
      return storedTheme;
    }

    return systemThemeQuery.matches ? "dark" : "light";
  }

  function applyTheme(theme) {
    const root = document.documentElement;
    root.classList.toggle("dark", theme === "dark");
    root.classList.toggle("light", theme === "light");
    root.dataset.theme = theme;
    document.dispatchEvent(
      new CustomEvent("themechange", {
        detail: { theme },
      }),
    );
  }

  function syncThemeButton() {
    if (!(themeButton instanceof HTMLButtonElement)) {
      return;
    }

    const theme = document.documentElement.dataset.theme ?? getPreferredTheme();
    const nextTheme = theme === "dark" ? "light" : "dark";
    const label = `Switch to ${nextTheme} mode`;
    const lightIcon = themeButton.querySelector('[data-theme-icon="light"]');
    const darkIcon = themeButton.querySelector('[data-theme-icon="dark"]');

    lightIcon?.classList.toggle("hidden", theme !== "dark");
    darkIcon?.classList.toggle("hidden", theme === "dark");
    themeButton.setAttribute("aria-label", label);
    themeButton.title = label;
  }

  function syncFullscreenButton() {
    const isFullscreen = Boolean(document.fullscreenElement);
    const label = isFullscreen ? "Exit fullscreen" : "Enter fullscreen";

    fullscreenButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      button.setAttribute("aria-label", label);
      button.title = label;

      const enterIcon = button.querySelector('[data-fullscreen-icon="enter"]');
      const exitIcon = button.querySelector('[data-fullscreen-icon="exit"]');

      enterIcon?.classList.toggle("hidden", isFullscreen);
      exitIcon?.classList.toggle("hidden", !isFullscreen);
    });
  }

  async function toggleFullscreen() {
    if (!document.fullscreenEnabled) {
      return;
    }

    if (document.fullscreenElement) {
      await document.exitFullscreen();
      return;
    }

    await document.documentElement.requestFullscreen();
  }

  function renderShutdownScreen() {
    toggleVisibility(shutdownOverlay, false);
    toggleVisibility(shutdownScreen, true);
    document.title = "SESSION_TERMINATED";
  }

  function toggleShutdownOverlay(isOpen) {
    toggleVisibility(shutdownOverlay, isOpen);

    if (isOpen) {
      shutdownConfirmButton?.focus();
    } else {
      const firstCloseButton = closeButtons[0];
      if (firstCloseButton instanceof HTMLButtonElement) {
        firstCloseButton.focus();
      }
    }
  }

  function attemptWindowClose() {
    toggleShutdownOverlay(false);
    window.close();

    // Some browsers only allow closing a tab after it has been script-targeted.
    setTimeout(() => {
      window.open("", "_self");
      window.close();
    }, 25);

    // Last-resort fallback when the browser refuses to close user-opened tabs.
    setTimeout(() => {
      if (!document.hidden) {
        renderShutdownScreen();
        window.location.replace("about:blank");
      }
    }, 150);
  }

  themeButton?.addEventListener("click", () => {
    const currentTheme =
      document.documentElement.dataset.theme === "dark" ? "dark" : "light";
    const nextTheme = currentTheme === "dark" ? "light" : "dark";

    localStorage.setItem(themeStorageKey, nextTheme);
    applyTheme(nextTheme);
    syncThemeButton();
  });
  closeButtons.forEach((button) => {
    button.addEventListener("click", () => {
      toggleMobileMenu(false);
      toggleShutdownOverlay(true);
    });
  });
  fullscreenButtons.forEach((button) => {
    button.addEventListener("click", () => {
      toggleFullscreen().catch(() => {
        syncFullscreenButton();
      });
      toggleMobileMenu(false);
    });
  });
  shutdownCancelButton?.addEventListener("click", () =>
    toggleShutdownOverlay(false),
  );
  shutdownConfirmButton?.addEventListener("click", attemptWindowClose);

  shutdownOverlay?.addEventListener("click", (event) => {
    if (event.target === shutdownOverlay) {
      toggleShutdownOverlay(false);
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      toggleMobileMenu(false);
      toggleShutdownOverlay(false);
    }
  });

  mobileMenuButton?.addEventListener("click", () => {
    const isOpen = mobileMenuButton.getAttribute("aria-expanded") === "true";
    toggleMobileMenu(!isOpen);
  });

  mobileNavLinks.forEach((link) => {
    link.addEventListener("click", () => {
      toggleMobileMenu(false);
    });
  });

  function syncActiveNavigation() {
    const navLinks = document.querySelectorAll("[data-nav-link]");

    navLinks.forEach((link) => {
      if (!(link instanceof HTMLAnchorElement)) {
        return;
      }

      const linkUrl = new URL(link.href, window.location.origin);
      const currentPathname =
        window.location.pathname.replace(/\/+$/, "") || "/";
      const linkPathname = linkUrl.pathname.replace(/\/+$/, "") || "/";
      const currentHashname = window.location.hash;
      const isActive = linkUrl.hash
        ? currentPathname === linkPathname &&
          (currentHashname
            ? currentHashname === linkUrl.hash
            : linkUrl.hash === "#system")
        : currentPathname === linkPathname;

      const activeClasses =
        link.dataset.activeClass?.split(" ").filter(Boolean) ?? [];
      const inactiveClasses =
        link.dataset.inactiveClass?.split(" ").filter(Boolean) ?? [];

      activeClasses.forEach((className) => {
        link.classList.toggle(className, isActive);
      });
      inactiveClasses.forEach((className) => {
        link.classList.toggle(className, !isActive);
      });
    });
  }

  document.addEventListener("fullscreenchange", syncFullscreenButton);
  document.addEventListener("themechange", syncThemeButton);
  systemThemeQuery.addEventListener("change", (event) => {
    if (localStorage.getItem(themeStorageKey)) {
      return;
    }

    applyTheme(event.matches ? "dark" : "light");
    syncThemeButton();
  });
  window.addEventListener("hashchange", syncActiveNavigation);
  window.addEventListener("resize", () => {
    if (window.innerWidth >= 768) {
      toggleMobileMenu(false);
    }
  });

  window.addEventListener("storage", (event) => {
    console.log("storage", event);

    if (event.key === "theme-preference") {
      applyTheme(event.newValue);

      syncThemeButton();
    }
  });

  applyTheme(getPreferredTheme());
  toggleMobileMenu(false);
  syncThemeButton();
  syncFullscreenButton();
  syncActiveNavigation();
</script>
