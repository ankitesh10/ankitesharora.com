---
const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const currentHash = Astro.url.hash;

const footerLinks = [
  { href: "/blog", label: "DEBUG_LOGS" },
  { href: "/#system", label: "SYSTEM_STATUS" },
  { href: "/resume", label: "LICENSE.TXT" },
  { href: "/bot", label: "BOT_SHELL", className: "hidden md:inline" },
].map((link) => {
  const url = new URL(link.href, Astro.url);
  const linkPath = url.pathname.replace(/\/+$/, "") || "/";
  const active = url.hash
    ? currentPath === linkPath &&
      (currentHash ? currentHash === url.hash : url.hash === "#system")
    : currentPath === linkPath;

  return {
    ...link,
    active,
  };
});
---

<footer
  class="fixed bottom-0 left-0 right-0 z-50 flex h-12 items-center justify-between border-t-2 border-chrome-border bg-chrome px-4 md:px-6 text-chrome-foreground shadow-[0_-1px_0_0_var(--color-border-muted)]"
>
  <div
    class="flex items-center gap-4 font-label text-[10px] leading-tight text-chrome-muted"
  >
    <span class="font-bold text-accent">ANKITESH_ARORA</span>
    <span class="hidden md:inline"
      >© 2026 ANKITESH_ARORA // BIT_REF: 0b101010</span
    >
  </div>

  <div class="flex gap-4 font-label text-[10px] uppercase md:gap-6">
    {
      footerLinks.map(({ href, label, active, className }) => (
        <a
          href={href}
          class:list={[
            className,
            active
              ? "text-accent underline underline-offset-2"
              : "text-chrome-muted hover:text-accent",
          ]}
        >
          {label}
        </a>
      ))
    }
  </div>
</footer>
