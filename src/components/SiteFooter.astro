---
const footerLinks = [
  { href: "#", label: "DEBUG_LOGS", active: true },
  { href: "#", label: "SYSTEM_STATUS" },
  { href: "#", label: "LICENSE.TXT" },
];
---

<footer
  class="fixed bottom-0 left-0 right-0 z-50 flex h-12 items-center justify-between border-t-2 border-ink-subtle/30 bg-ink px-4 md:px-6"
>
  <div class="flex items-center gap-4 font-label text-[10px] leading-tight text-ink-subtle">
    <span class="font-bold text-accent">ANALOG_DIGITALIST</span>
    <span class="hidden md:inline">© 2024 ANALOG_DIGITALIST // BIT_REF: 0x00FF41</span>
  </div>

  <div class="flex gap-4 font-label text-[10px] uppercase md:gap-6">
    {
      footerLinks.map(({ href, label, active }) => (
        <a
          href={href}
          class:list={[
            active ? "text-accent underline" : "text-ink-subtle hover:text-accent",
          ]}
        >
          {label}
        </a>
      ))
    }
  </div>
</footer>
