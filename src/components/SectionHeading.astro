---
interface Props {
  title: string;
  meta?: string;
}

const { title, meta } = Astro.props;
---

<div class="flex items-baseline justify-between border-b-2 border-ink pb-2">
  <h2 class="font-headline text-2xl font-bold uppercase tracking-tight">{title}</h2>
  {meta && <span class="font-label text-xs text-ink-muted">{meta}</span>}
</div>
